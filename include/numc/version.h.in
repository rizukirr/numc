#ifndef NUMC_VERSION_H
#define NUMC_VERSION_H

/**
 * @file version.h
 * @brief numc library version information.
 *
 * This header is generated by CMake from version.h.in.
 * Do not edit manually.
 */

#define NUMC_VERSION_MAJOR @numc_VERSION_MAJOR@
#define NUMC_VERSION_MINOR @numc_VERSION_MINOR@
#define NUMC_VERSION_PATCH @numc_VERSION_PATCH@

#define NUMC_VERSION_SUFFIX "@NUMC_VERSION_SUFFIX@"

#define NUMC_VERSION_STRING "@numc_VERSION@@NUMC_VERSION_SUFFIX@"

#endif /* NUMC_VERSION_H */
